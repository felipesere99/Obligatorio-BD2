# Plantilla de variables de entorno. Copiala a .env y completá los valores:
#   cp .env.example .env
# El .env real está en .gitignore (no se sube); este .example sí se versiona.

# ---------- MySQL local (Docker) ----------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ticketing
MYSQL_USER=ticketing
MYSQL_PASSWORD=ticketing

# ---------- Base compartida de la UCU (Grupo 4) ----------
UCU_DB_HOST=mysql.reto-ucu.net
UCU_DB_PORT=50006
UCU_DB_NAME=XR_Grupo4
UCU_DB_USER=xr_g4_admin
UCU_DB_PASSWORD=

